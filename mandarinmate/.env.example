# Firebase Configuration
# Copy this file to .env and fill in your actual Firebase credentials
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PROJECT_NUMBER=your_project_number
FIREBASE_STORAGE_BUCKET=your_storage_bucket
FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# Platform-specific API Keys (Create separate keys in Google Cloud Console for each platform)
FIREBASE_API_KEY_ANDROID=your_android_api_key
FIREBASE_API_KEY_IOS=your_ios_api_key
FIREBASE_API_KEY_WEB=your_web_api_key

# Platform-specific App IDs (Get these from Firebase Console)
FIREBASE_APP_ID_ANDROID=your_android_app_id
FIREBASE_APP_ID_IOS=your_ios_app_id
FIREBASE_APP_ID_WEB=your_web_app_id
