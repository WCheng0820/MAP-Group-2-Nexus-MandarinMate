# Firebase Configuration - Copy to .env and fill in your actual values
# DO NOT commit .env file to Git!

# Android Firebase API Key
FIREBASE_ANDROID_API_KEY=AIzaSy...your_actual_key_here...

# iOS Firebase API Key  
FIREBASE_IOS_API_KEY=AIzaSy...your_actual_key_here...

# Firebase App IDs
FIREBASE_ANDROID_APP_ID=1:253053635674:android:944bb7b4ba0df1f0af5c63
FIREBASE_IOS_APP_ID=1:253053635674:ios:your_ios_app_id_here

# Firebase Project Info
FIREBASE_PROJECT_ID=mandarinmate-utm
FIREBASE_MESSAGING_SENDER_ID=253053635674
FIREBASE_STORAGE_BUCKET=mandarinmate-utm.appspot.com

# Firebase Auth Domain
FIREBASE_AUTH_DOMAIN=mandarinmate-utm.firebaseapp.com
