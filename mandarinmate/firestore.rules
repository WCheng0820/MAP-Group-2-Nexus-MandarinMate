rules_version = '2';
  service cloud.firestore {
    match /databases/{database}/documents {

      function signedIn() {
        return request.auth != null;
      }

      function isAdmin() {
        return signedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }

      function isTutor() {
        return signedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'tutor';
      }

      match /users/{userId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.auth.uid == userId;
        allow update: if isAdmin() || (
          signedIn()
          && request.auth.uid == userId
          // Allow updating specific progress fields, but prevent modifying roles/emails
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'xp', 
            'xpPoints', 
            'completedLessons', 
            'starredItems',
            'username' // add any other fields the user should be allowed to edit themselves
          ])
        );
        allow delete: if isAdmin();
      }

      match /lessons/{lessonId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin() || isTutor();
      }

      match /lessons/{lessonId}/vocabulary/{vocabId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin() || isTutor();
      }

      match /announcements/{announcementId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin() || isTutor();
      }

      match /flashcard_levels/{levelId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin() || isTutor();
      }

      match /flashcard_levels/{levelId}/cards/{cardId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin() || isTutor();
      }

      match /forum_posts/{postId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;
        allow update: if signedIn() && (
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['title', 'content', 'category'])) ||
          (resource.data.authorId == request.auth.uid || isAdmin())
        );
        allow delete: if isAdmin() || (signedIn() && resource.data.authorId == request.auth.uid);
      }

      match /forum_posts/{postId}/comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;
        allow update: if signedIn() && resource.data.authorId == request.auth.uid;
        allow delete: if isAdmin() || isTutor() || (signedIn() && (resource.data.authorId == request.auth.uid || get(/databases/$(database)/documents/forum_posts/$(postId)).data.authorId == request.auth.uid));
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }
  }
